{
  "name": "wfc-monorepo-root",
  "packageManager": "pnpm@9.2.0",
  "private": true,
  "description": "Monorepo containing a Vue app and a TS library",
  "scripts": {
    "dev": "pnpm -filter vue-app dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm run clean:ts && pnpm -r --parallel typecheck",
    "clean:ts": "find . -name '*.tsbuildinfo' -delete",
    "build:wasm": "wasm-pack build ../wfc-rust --target web --release",
    "build:wasm-debug": "wasm-pack build ../wfc-rust --target web --debug"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}