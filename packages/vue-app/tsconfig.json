{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vue-app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@unstoppablecarl/wfc-js": [
        "../wfc-js"
      ],
      "@unstoppablecarl/wfc-rust": [
        "../wfc-rust/pkg/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "src/env.d.ts"
  ],
  "references": [
    {
      "path": "../wfc-js"
    }
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}